generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model skills {
  id         BigInt       @id @default(autoincrement())
  name       String       @db.VarChar
  created_at DateTime?    @default(now()) @db.Timestamptz(6)
  user_skill user_skill[]
}

model study_record {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title      String    @db.VarChar
  time       Int?
  created_at DateTime? @default(now()) @db.Timestamptz(6)

  @@map("study-record")
}

model todos {
  id         BigInt   @id @default(autoincrement())
  created_at DateTime @default(now()) @db.Timestamptz(6)
  title      String?  @db.VarChar
  done       Boolean? @default(false)
}

model user_skill {
  id         BigInt    @default(autoincrement())
  user_id    String    @db.VarChar
  skill_id   BigInt
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  skills     skills    @relation(fields: [skill_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users      users     @relation(fields: [user_id], references: [user_id], onDelete: NoAction, onUpdate: NoAction)

  @@id([id, user_id, skill_id])
}

model users {
  user_id     String       @id @db.VarChar
  name        String       @db.VarChar
  description String?
  github_id   String?      @db.VarChar
  qiita_id    String?      @db.VarChar
  x_id        String?      @db.VarChar
  created_at  DateTime?    @default(now()) @db.Timestamptz(6)
  user_skill  user_skill[]
}

model Category {
  id    String @id @default(cuid())
  slug  String @unique  // "announcements" etc.
  name  String          // "お知らせ" etc.
  posts Post[]

  @@map("category")
}

model Post {
  id         String   @id @default(cuid())
  user       String
  title      String
  content    String
  post_at    DateTime @default(now())
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  @@map("posts")
}
